name: Claude Code

on:
  issue_comment:
    types: [created]
  pull_request_review_comment:
    types: [created]
  issues:
    types: [opened, assigned]
  pull_request_review:
    types: [submitted]

jobs:
  claude:
    if: |
      (github.event_name == 'issue_comment' && github.event.comment.user.login == '{{ .GitHubOwner }}' && contains(github.event.comment.body, '@claude')) ||
      (github.event_name == 'pull_request_review_comment' && github.event.comment.user.login == '{{ .GitHubOwner }}' && contains(github.event.comment.body, '@claude')) ||
      (github.event_name == 'pull_request_review' && github.event.review.user.login == '{{ .GitHubOwner }}' && contains(github.event.review.body, '@claude')) ||
      (github.event_name == 'issues' && github.event.issue.user.login == '{{ .GitHubOwner }}' && (contains(github.event.issue.body, '@claude') || contains(github.event.issue.title, '@claude')))
    runs-on: ubuntu-latest
    permissions:
      contents: read
      pull-requests: read
      issues: read
      id-token: write
      actions: read
    steps:
      - name: Checkout repository
        uses: actions/checkout@v6
        with:
          fetch-depth: 1

      - name: Run Claude Code
        id: claude
        uses: anthropics/claude-code-action@v1
        with:
          claude_code_oauth_token: ${{"{{"}} secrets.CLAUDE_CODE_OAUTH_TOKEN {{"}}"}}
          additional_permissions: |
            actions: read
