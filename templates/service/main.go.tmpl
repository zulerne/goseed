package main

import (
	"context"
	"fmt"
	"log/slog"
	"os"
	"os/signal"
	"syscall"

	"{{ .ModulePath }}/internal/config"
	"{{ .ModulePath }}/internal/handler"
	"{{ .ModulePath }}/internal/server"
)

var (
	version = "dev"
	commit  = "none"
)

func main() {
	if err := run(); err != nil {
		slog.Error("fatal error", "error", err)
		os.Exit(1)
	}
}

func run() error {
	ctx, stop := signal.NotifyContext(context.Background(), syscall.SIGINT, syscall.SIGTERM)
	defer stop()

	cfg, err := config.Load()
	if err != nil {
		return fmt.Errorf("load config: %w", err)
	}

	slog.Info("starting {{ .ProjectName }}", "version", version, "commit", commit)

	h := handler.New()
	srv := server.New(cfg.Addr(), h.Routes())

	return srv.Run(ctx)
}
