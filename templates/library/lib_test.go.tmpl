package {{ .ProjectName }}_test

import (
	"testing"

	"{{ .ModulePath }}"
)

func TestHello(t *testing.T) {
	tests := []struct {
		name string
		input string
		want string
	}{
		{
			name:  "simple name",
			input: "World",
			want:  "Hello, World!",
		},
		{
			name:  "empty name",
			input: "",
			want:  "Hello, !",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			got := {{ .ProjectName }}.Hello(tt.input)
			if got != tt.want {
				t.Errorf("Hello(%q) = %q, want %q", tt.input, got, tt.want)
			}
		})
	}
}
